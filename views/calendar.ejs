<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Event Calendar | Student Portal</title>

  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

  <style>
    :root {
      --primary: #4f46e5;
      --bg-sky: url('https://images.unsplash.com/photo-1513002749550-c59d786b8e6c?auto=format&fit=crop&w=1920&q=80');
    }

    body {
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 0;
      background: var(--bg-sky);
      background-size: cover;
      background-attachment: fixed;
      min-height: 100vh;
      color: #1f2937;
    }

    /* Navbar */
    .navbar {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      padding: 1rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 15px rgba(0,0,0,0.05);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .logo {
      font-weight: 700;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .user-profile {
      display: flex;
      align-items: center;
      gap: 12px;
      background: white;
      padding: 6px 16px;
      border-radius: 50px;
      border: 1px solid #e5e7eb;
    }

    /* Layout */
    .main-container {
      max-width: 1300px;
      margin: 40px auto;
      padding: 0 20px;
      display: flex;
      gap: 30px;
    }

    .calendar-card {
      flex: 3;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 24px;
      padding: 30px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    }

    .sidebar {
      flex: 1;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 24px;
      padding: 25px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
      height: fit-content;
    }

    header h2 {
      margin: 0 0 20px;
      font-size: 1.6rem;
      text-align: center;
    }

    /* Registered Events Sidebar */
    .registered-item {
      background: #f3f4f6;
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 12px;
      transition: 0.2s ease;
    }

    .registered-item:hover {
      background: #e5e7eb;
    }

    .registered-item strong {
      display: block;
      font-size: 0.95rem;
    }

    .registered-item small {
      color: #6b7280;
      font-size: 0.8rem;
    }

    /* FullCalendar Styling */
    .fc .fc-toolbar-title {
      font-size: 1.4rem !important;
      font-weight: 600;
    }

    .fc .fc-button-primary {
      background-color: white !important;
      border-color: #e5e7eb !important;
      color: #374151 !important;
      text-transform: capitalize;
    }

    .fc .fc-button-active {
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
      color: white !important;
    }

    .fc-event {
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 6px !important;
      background-color: var(--primary) !important;
      border: none !important;
      font-size: 0.85rem;
      transition: 0.2s ease;
    }

    .fc-event:hover {
      transform: scale(1.03);
    }

    @media (max-width: 900px) {
      .main-container {
        flex-direction: column;
      }
    }
  </style>
</head>

<body>

<nav class="navbar">
  <div class="logo">
    <i class="fas fa-calendar-alt" style="color: var(--primary);"></i>
    <span>StudentHub</span>
  </div>
  <div class="user-profile">
    <i class="fas fa-user-circle" style="color: #9ca3af;"></i>
    <span><%= student.name %></span>
    <a href="/logout" style="color: #ef4444; text-decoration: none;">
      <i class="fas fa-sign-out-alt"></i>
    </a>
  </div>
</nav>

<main class="main-container">

  <!-- Calendar -->
  <div class="calendar-card">
    <header>
      <h2>Upcoming Events</h2>
    </header>
    <div id="calendar"></div>
  </div>

  <!-- Sidebar -->
  <div class="sidebar">
    <h2>My Registered Events</h2>

    <% if (registeredEvents.length === 0) { %>
      <p style="color:#6b7280;">No registrations yet.</p>
    <% } else { %>
      <% registeredEvents.forEach(e => { %>
        <div class="registered-item">
          <strong><%= e.title %></strong>
          <small><%= new Date(e.event_date).toDateString() %></small>
        </div>
      <% }) %>
    <% } %>

  </div>

</main>

<script>
  const events = <%- JSON.stringify(events) %>;

  document.addEventListener('DOMContentLoaded', function() {

    const calendar = new FullCalendar.Calendar(
      document.getElementById('calendar'),
      {
        initialView: 'dayGridMonth',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek'
        },
        height: 'auto',
        events: events.map(e => ({
          id: e.id,
          title: e.title + " (" + (e.max_seats - e.seats_filled) + " left)",
          start: e.event_date
        })),
        eventClick: function(info) {
          window.location.href = "/event/" + info.event.id;
        }
      }
    );

    calendar.render();
  });
</script>

</body>
</html>