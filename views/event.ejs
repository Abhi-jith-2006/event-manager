<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> | Event Registration</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

  <style>
    :root {
      --primary-color: #4f46e5;
      --accent-color: #10b981;
      --danger-color: #ef4444;
      --text-dark: #1f2937;
      --bg-light: #f3f4f6;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: var(--bg-light);
      margin: 0;
      line-height: 1.6;
      color: var(--text-dark);
    }

    .hero-banner {
      width: 100%;
      height: 350px;
      background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                  url('https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?auto=format&fit=crop&w=1200&q=80');
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 3rem;
      margin: 0;
      text-shadow: 2px 2px 6px rgba(0,0,0,0.6);
    }

    .container {
      max-width: 800px;
      margin: -50px auto 40px;
      padding: 0 20px;
    }

    .event-card {
      background: white;
      padding: 40px;
      border-radius: 16px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin: 30px 0;
      text-align: center;
    }

    .stat-box {
      padding: 15px;
      background: #f9fafb;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
    }

    .stat-number {
      display: block;
      font-size: 1.6rem;
      font-weight: bold;
      color: var(--primary-color);
    }

    .btn {
      display: block;
      width: 100%;
      padding: 14px;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: 0.2s ease;
      margin-top: 15px;
    }

    .btn-register {
      background-color: var(--primary-color);
      color: white;
    }

    .btn-register:hover {
      background-color: #4338ca;
    }

    .btn-cancel {
      background-color: var(--danger-color);
      color: white;
    }

    .btn-cancel:hover {
      background-color: #dc2626;
    }

    .success-box {
      background: #d1fae5;
      color: #065f46;
      padding: 12px;
      border-radius: 10px;
      margin-bottom: 15px;
      font-weight: 500;
    }

    .full-notice {
      background: #fee2e2;
      color: var(--danger-color);
      padding: 15px;
      border-radius: 10px;
      font-weight: bold;
      text-align: center;
    }

    .back-link {
      display: inline-block;
      margin-top: 25px;
      color: #6b7280;
      text-decoration: none;
    }

    .back-link:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <header class="hero-banner">
    <div class="hero-content">
      <h1><%= event.title %></h1>
    </div>
  </header>

  <main class="container">
    <article class="event-card">

      <h2>About This Event</h2>
      <p><%= event.description %></p>

      <div class="stats-grid">
        <div class="stat-box">
          <span class="stat-number"><%= event.max_seats %></span>
          Total Seats
        </div>
        <div class="stat-box">
          <span class="stat-number"><%= registeredCount %></span>
          Registered
        </div>
        <div class="stat-box">
          <span class="stat-number" style="color: var(--accent-color);">
            <%= event.max_seats - registeredCount %>
          </span>
          Remaining
        </div>
      </div>

      <% if (alreadyRegistered) { %>

        <div class="success-box">
          <i class="fas fa-check-circle"></i>
          You are registered for this event.
        </div>

        <form method="POST" action="/cancel/<%= event.id %>">
          <button type="submit" class="btn btn-cancel">
            Cancel Registration
          </button>
        </form>

      <% } else if (registeredCount < event.max_seats) { %>

        <form method="POST" action="/register/<%= event.id %>">
          <button type="submit" class="btn btn-register">
            Secure My Spot
          </button>
        </form>

      <% } else { %>

        <div class="full-notice">
          <i class="fas fa-exclamation-circle"></i>
          This event is currently full.
        </div>

      <% } %>

      <a href="/calendar" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Calendar
      </a>

    </article>
  </main>

</body>
</html>