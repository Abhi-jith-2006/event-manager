<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> | Event Registration</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #4f46e5;
      --accent-color: #10b981;
      --danger-color: #ef4444;
      --text-dark: #1f2937;
      --bg-light: #f3f4f6;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: var(--bg-light);
      color: var(--text-dark);
      margin: 0;
      line-height: 1.6;
    }

    /* Banner Styles */
    .hero-banner {
      width: 100%;
      height: 350px;
      background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                  url('https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?auto=format&fit=crop&w=1200&q=80'); /* Default placeholder */
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 3rem;
      margin: 0;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }

    /* Container & Card */
    .container {
      max-width: 800px;
      margin: -50px auto 40px;
      padding: 0 20px;
    }

    .event-card {
      background: white;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    /* Stats Section */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin: 30px 0;
      text-align: center;
    }

    .stat-box {
      padding: 15px;
      background: #f9fafb;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
    }

    .stat-number {
      display: block;
      font-size: 1.5rem;
      font-weight: bold;
      color: var(--primary-color);
    }

    /* Registration Logic */
    .btn-reg {
      display: block;
      width: 100%;
      padding: 15px;
      background-color: var(--primary-color);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .btn-reg:hover {
      background-color: #4338ca;
    }

    .full-notice {
      text-align: center;
      background: #fee2e2;
      color: var(--danger-color);
      padding: 15px;
      border-radius: 8px;
      font-weight: bold;
    }

    .back-link {
      display: inline-block;
      margin-top: 25px;
      color: #6b7280;
      text-decoration: none;
    }

    .back-link:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <header class="hero-banner">
    <div class="hero-content">
      <h1><%= event.title %></h1>
    </div>
  </header>

  <main class="container">
    <article class="event-card">
      <h2>About This Event</h2>
      <p><%= event.description %></p>

      <div class="stats-grid">
        <div class="stat-box">
          <span class="stat-number"><%= event.max_seats %></span>
          <span class="stat-label">Total Seats</span>
        </div>
        <div class="stat-box">
          <span class="stat-number"><%= registeredCount %></span>
          <span class="stat-label">Registered</span>
        </div>
        <div class="stat-box">
          <span class="stat-number" style="color: var(--accent-color);">
            <%= event.max_seats - registeredCount %>
          </span>
          <span class="stat-label">Remaining</span>
        </div>
      </div>

      <% if (registeredCount < event.max_seats) { %>
        <form method="POST" action="/register/<%= event.id %>">
          <button type="submit" class="btn-reg">Secure My Spot</button>
        </form>
      <% } else { %>
        <div class="full-notice">
          <i class="fas fa-exclamation-circle"></i> This event is currently full.
        </div>
      <% } %>

      <a href="/calendar" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Calendar
      </a>
    </article>
  </main>

</body>
</html>